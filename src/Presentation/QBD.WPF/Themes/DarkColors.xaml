<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="ThemeWindowBackground" Color="#1E1E1E"/>
    <SolidColorBrush x:Key="ThemeControlBackground" Color="#2D2D30"/>
    <SolidColorBrush x:Key="ThemeForeground" Color="#F1F1F1"/>
    <SolidColorBrush x:Key="ThemeBorderBrush" Color="#3F3F46"/>
    <SolidColorBrush x:Key="ThemePrimary" Color="#0D47A1"/>
    <SolidColorBrush x:Key="ThemePrimaryForeground" Color="#F1F1F1"/>
    <SolidColorBrush x:Key="ThemeMenuBackground" Color="#2D2D30"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.MenuBrushKey}" Color="#2D2D30"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.MenuBarBrushKey}" Color="#1E1E1E"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.MenuTextBrushKey}" Color="#F1F1F1"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#2D2D30"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#F1F1F1"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#2D2D30"/>
</ResourceDictionary>